{
  "schema_version": 2,
  "type": "shift_right_click",

  "hand": {
    "hand": "main",
    "match": "#minecraft:pickaxes",
    "consume": { "mode": "durability", "chance": 1.0 },
    "nbt_predicates": [
      { "path": "Damage", "int_range": [0, 1000] },
      { "path": "Enchantments[].lvl", "int_range": [1, 5], "where": "{id:\"minecraft:efficiency\"}" }
    ]
  },

  "target": {
    "kind": "block",
    "match": "minecraft:stone",
    "state": { "blacklist": {} }
  },

  "transformation": {
    "chance": 0.5,
    "into": { "kind": "block", "id": "minecraft:cobblestone" },
    "sound": "minecraft:block.stone.break",
    "particles": "minecraft:stone"
  },

  "rewards": {
    "rolls": 2,
    "guaranteed": [ { "match": "minecraft:cobblestone", "count": 1 } ],
    "weighted": [
      { "match": "minecraft:iron_nugget", "weight": 20, "count": { "min": 1, "max": 2 } },
      { "match": "minecraft:air", "weight": 80 }
    ],
    "fortune": { "enchant": "minecraft:fortune", "factor": 1.0 }
  },

  "costs": {
    "hunger": { "chance": 0.25, "amount": { "min": 1, "max": 2 } }
  },

  "effects": [
    { "id": "minecraft:haste", "duration": 100, "amplifier": 0, "chance": 0.25 }
  ],
  "sound": "minecraft:block.stone.hit",
  "particles": "minecraft:stone",

  "conditions": {
    "time": "night",
    "weather": ["clear", "rain"],
    "y_range": [-64, 40],
    "light": { "max": 7 },
    "player_state": { "min_food": 4 }
  }
}
