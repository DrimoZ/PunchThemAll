{
  "schema_version": 2,
  "type": "right_click",
  "hand": {
    "hand": "any",
    "match": "#minecraft:hoes",
    "consume": { "mode": "durability" },
    "nbt_predicates": [
      { "path": "Damage", "int_range": [0, 500] },
      { "path": "Enchantments[].lvl", "int_range": [2, 7], "where": "{id:\"minecraft:unbreaking\"}" }
    ]
  },
  "rewards": {
    "weighted": [
      { "match": "#forge:seeds", "weight": 10, "count": { "min": 1, "max": 3 } },
      { "match": "minecraft:air", "weight": 90 }
    ]
  }
}
