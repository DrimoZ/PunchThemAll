{
  "schema_version": 2,
  "type": "shift_left_click",

  "hand": {
    "hand": "main",
    "match": "#minecraft:shovels",
    "consume": { "mode": "durability", "chance": 1.0 },
    "nbt": {
      "blacklist": "{Enchantments:[{id:\"minecraft:silk_touch\"}]}"
    }
  },

  "target": {
    "kind": "block",
    "match": "minecraft:gravel"
  },

  "transformation": {
    "chance": 0.7,
    "into": { "kind": "block", "id": "minecraft:sand" },
    "particles": "minecraft:sand"
  },

  "rewards": {
    "weighted": [
      { "match": "minecraft:clay_ball", "weight": 10, "count": { "min": 1, "max": 3 } },
      { "match": "minecraft:air", "weight": 90 }
    ]
  },

  "costs": {
    "hunger": { "chance": 0.1, "amount": { "min": 1, "max": 3 } }
  }
}
